# Copy this file to .env and fill in real values. Never commit .env itself.

# SQLite is fine for local dev/demo. Swap for a Postgres URL in production.
DATABASE_URL=sqlite:///./ledger.db

# Required for the Advocate (core/advocate.py) to call Gemini.
GEMINI_API_KEY=your_gemini_api_key_here

# The frontend origin allowed by CORS. Must match exactly (scheme + host +
# port) — no trailing slash.
FRONTEND_ORIGIN=http://localhost:5173
